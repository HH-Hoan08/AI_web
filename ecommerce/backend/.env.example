# ===========================
# LUXE MARKET - ENV CONFIG
# ===========================

# Server
NODE_ENV=development
PORT=5000

# MongoDB
MONGO_URI=mongodb://localhost:27017/luxury_market
# Hoặc MongoDB Atlas:
# MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/luxe_market

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_chars
JWT_EXPIRES_IN=7d
JWT_COOKIE_EXPIRES=7

# Email (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=LUXURY MARKET <noreply@luxemarket.vn>

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# File upload
MAX_FILE_UPLOAD=5242880
FILE_UPLOAD_PATH=./uploads

# Admin credentials (initial seed)
ADMIN_EMAIL=admin@luxemarket.vn
ADMIN_PASSWORD=Admin@123456

# Rate limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100
